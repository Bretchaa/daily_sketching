<div class="min-h-screen flex items-center justify-center px-6" style="background: #f5f2ee;">
  <div class="w-full" style="max-width: 26rem;">
    <div class="bg-white rounded-[2rem] shadow-md" style="padding: 2.5rem; border: 1px solid #e2ddd8;">

      <h1 class="font-handwritten" style="font-size: 1.75rem; color: #1a1a1a; margin-bottom: 0.25rem;">Set a new password</h1>
      <p class="font-sans" style="font-size: 0.9rem; color: #888; margin-bottom: 2rem;">Choose something you'll remember.</p>

      <% if @error %>
        <p class="font-sans" style="font-size: 0.85rem; color: #e53e3e; margin-bottom: 1rem; background: #fff5f5; padding: 0.75rem 1rem; border-radius: 0.75rem;"><%= @error %></p>
      <% end %>

      <%= form_with url: new_password_reset_path, method: :patch do |f| %>
        <%= hidden_field_tag :token, params[:token] %>
        <div style="display: flex; flex-direction: column; gap: 1rem;">
          <%= f.password_field :password, placeholder: "New password (6+ characters)", required: true,
            style: "width: 100%; padding: 0.75rem 1rem; border: 1.5px solid #e2ddd8; border-radius: 0.75rem; font-size: 0.95rem; outline: none; box-sizing: border-box;" %>
          <%= f.submit "Set new password", class: "btn btn-black btn-lg w-full rounded-2xl" %>
        </div>
      <% end %>

    </div>
  </div>
</div>
