<div class="min-h-screen flex items-center justify-center px-6" style="background: #f5f2ee;">
  <div class="w-full" style="max-width: 26rem;">
    <div class="bg-white rounded-[2rem] shadow-md" style="padding: 2.5rem; border: 1px solid #e2ddd8;">

      <h1 class="font-handwritten" style="font-size: 1.75rem; color: #1a1a1a; margin-bottom: 0.25rem;">Forgot your password?</h1>
      <p class="font-sans" style="font-size: 0.9rem; color: #888; margin-bottom: 2rem;">Enter your email and we'll send you a reset link.</p>

      <%= form_with url: new_password_reset_path, method: :post do |f| %>
        <div style="display: flex; flex-direction: column; gap: 1rem;">
          <%= f.email_field :email, placeholder: "Your email", required: true,
            style: "width: 100%; padding: 0.75rem 1rem; border: 1.5px solid #e2ddd8; border-radius: 0.75rem; font-size: 0.95rem; outline: none; box-sizing: border-box;" %>
          <%= f.submit "Send reset link", class: "btn btn-black btn-lg w-full rounded-2xl" %>
        </div>
      <% end %>

      <p class="font-sans text-center" style="margin-top: 1.5rem; font-size: 0.85rem; color: #888;">
        <%= link_to "Back to sign in", sign_in_path, style: "color: #1a1a1a; font-weight: 600;" %>
      </p>

    </div>
  </div>
</div>
