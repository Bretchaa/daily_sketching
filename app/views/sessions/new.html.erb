<div class="min-h-screen flex items-center justify-center px-6" style="background: #f5f2ee;">
  <div class="w-full" style="max-width: 26rem;">
    <div class="bg-white rounded-[2rem] shadow-md" style="padding: 2.5rem; border: 1px solid #e2ddd8;">

      <h1 class="font-handwritten" style="font-size: 1.75rem; color: #1a1a1a; margin-bottom: 0.25rem;">Welcome back</h1>
      <p class="font-sans" style="font-size: 0.9rem; color: #888; margin-bottom: 2rem;">Sign in to track your streak.</p>

      <% if @error %>
        <p class="font-sans" style="font-size: 0.85rem; color: #e53e3e; margin-bottom: 1rem; background: #fff5f5; padding: 0.75rem 1rem; border-radius: 0.75rem;"><%= @error %></p>
      <% end %>

      <%= form_with url: sign_in_path, method: :post do |f| %>
        <div style="display: flex; flex-direction: column; gap: 1rem;">
          <div>
            <label class="font-sans" style="font-size: 0.8rem; font-weight: 600; color: #555; display: block; margin-bottom: 0.4rem;">Email</label>
            <%= f.email_field :email, required: true, style: "width: 100%; padding: 0.75rem 1rem; border: 1.5px solid #e2ddd8; border-radius: 0.75rem; font-size: 0.95rem; outline: none; box-sizing: border-box;" %>
          </div>
          <div>
            <label class="font-sans" style="font-size: 0.8rem; font-weight: 600; color: #555; display: block; margin-bottom: 0.4rem;">Password</label>
            <%= f.password_field :password, required: true, style: "width: 100%; padding: 0.75rem 1rem; border: 1.5px solid #e2ddd8; border-radius: 0.75rem; font-size: 0.95rem; outline: none; box-sizing: border-box;" %>
          </div>
          <div style="display: flex; justify-content: flex-end;">
            <%= link_to "Forgot password?", new_password_reset_path, style: "font-size: 0.8rem; color: #aaa; text-decoration: none;" %>
          </div>
          <%= f.submit "Sign in", class: "btn btn-black btn-lg w-full rounded-2xl", style: "margin-top: 0.5rem;" %>
        </div>
      <% end %>

      <div style="display: flex; align-items: center; gap: 0.75rem; margin: 1.5rem 0;">
        <div style="flex: 1; height: 1px; background: #e2ddd8;"></div>
        <span class="font-sans" style="font-size: 0.8rem; color: #bbb;">or</span>
        <div style="flex: 1; height: 1px; background: #e2ddd8;"></div>
      </div>

      <%= link_to "/auth/google_oauth2", style: "display: flex; align-items: center; justify-content: center; gap: 0.6rem; background: white; color: #333; border: 1.5px solid #e2ddd8; border-radius: 0.75rem; padding: 0.75rem 1rem; font-size: 0.9rem; font-weight: 600; text-decoration: none; width: 100%;" do %>
        <svg width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg"><path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4"/><path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 009 18z" fill="#34A853"/><path d="M3.964 10.71A5.41 5.41 0 013.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 000 9c0 1.452.348 2.827.957 4.042l3.007-2.332z" fill="#FBBC05"/><path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 00.957 4.958L3.964 6.29C4.672 4.163 6.656 3.58 9 3.58z" fill="#EA4335"/></svg>
        Continue with Google
      <% end %>

      <p class="font-sans text-center" style="margin-top: 1.5rem; font-size: 0.85rem; color: #888;">
        No account? <%= link_to "Sign up", sign_up_path, style: "color: #1a1a1a; font-weight: 600;" %>
      </p>

    </div>
  </div>
</div>
