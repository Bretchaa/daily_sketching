<!DOCTYPE html>
<html data-theme="light">
  <head>
    <title><%= content_for(:title) || "Daily Sketching" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Itim&display=swap" rel="stylesheet">

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png?v=2" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png?v=2">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body class="font-sans">
  <script>
    function toggleCheer(submissionId, btn) {
      var csrf = document.querySelector('meta[name="csrf-token"]').content;
      fetch("/cheers", {
        method: "POST",
        headers: { "Content-Type": "application/json", "X-CSRF-Token": csrf, "Accept": "application/json" },
        body: JSON.stringify({ submission_id: submissionId })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        btn.style.background = data.cheered ? "rgba(255,255,255,0.35)" : "rgba(255,255,255,0.15)";
        var count = document.getElementById("cheer-count-" + submissionId);
        count.textContent = data.total > 0 ? data.total : "";
        count.style.color = data.cheered ? "white" : "rgba(255,255,255,0.7)";
      });
    }
  </script>

    <%# Top left — mascot linking to home — hidden during drawing session %>
    <% unless (controller_name == 'drawings' && action_name == 'show') || (controller_name == 'home') %>
      <div style="position: fixed; top: 0; left: 0; z-index: 50; padding: 0.5rem 1rem;">
        <%= link_to root_path, style: "display: block; text-decoration: none;" do %>
          <%= image_tag "mascotte_DS.png", style: "width: 3.5rem; height: 3.5rem; object-fit: contain;", alt: "Home" %>
        <% end %>
      </div>
    <% end %>

    <%# Top right — profile + streak — hidden during drawing session %>
    <nav style="position: fixed; top: 0; right: 0; z-index: 50; padding: 1rem 1.25rem;<%= ' display: none;' if controller_name == 'drawings' && action_name == 'show' %>">
      <% if current_user %>
        <% nav_streak = current_user.streak %>
        <%= link_to account_path, style: "display: flex; align-items: center; gap: 0.5rem; text-decoration: none;" do %>
          <% if nav_streak > 0 %>
            <div style="position: relative; width: 1.8rem; height: 2.25rem; flex-shrink: 0;">
              <svg viewBox="0 0 36 48" fill="none" xmlns="http://www.w3.org/2000/svg" style="width: 100%; height: 100%; filter: drop-shadow(0 1px 4px rgba(255,212,0,0.6));">
                <path d="M24 2L4 26L15 26L11 46L32 22L21 22Z" fill="#FFD400"/>
              </svg>
              <span class="font-sans" style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; padding-left: 0.1rem; font-size: <%= nav_streak >= 10 ? '0.5rem' : '0.65rem' %>; font-weight: 900; color: #1a1a1a; line-height: 1;"><%= nav_streak %></span>
            </div>
          <% end %>
          <% if current_user.avatar_url.present? %>
            <img src="<%= current_user.avatar_url %>" style="width: 2.25rem; height: 2.25rem; border-radius: 999px; border: 2px solid rgba(255,255,255,0.8); box-shadow: 0 1px 4px rgba(0,0,0,0.12);">
          <% else %>
            <div style="width: 2.25rem; height: 2.25rem; border-radius: 999px; background: #1a1a1a; display: flex; align-items: center; justify-content: center; box-shadow: 0 1px 4px rgba(0,0,0,0.12);">
              <span class="font-sans" style="color: white; font-weight: 700; font-size: 0.75rem;"><%= current_user.username[0].upcase %></span>
            </div>
          <% end %>
        <% end %>
      <% else %>
        <%= link_to "Sign in", sign_in_path, class: "font-sans", style: "font-size: 0.85rem; font-weight: 600; color: #888; text-decoration: none;" %>
      <% end %>
    </nav>

    <%= yield %>

    <footer style="text-align: center; padding: 1.5rem; background: #f5f2ee;">
      <p class="font-sans" style="font-size: 0.78rem; color: #ccc;">
        <%= link_to "Privacy Policy", privacy_path, style: "color: #bbb; text-decoration: none;" %>
        <span style="margin: 0 0.5rem;">·</span>
        <%= link_to "Terms of Service", terms_path, style: "color: #bbb; text-decoration: none;" %>
      </p>
    </footer>

  </body>
</html>
