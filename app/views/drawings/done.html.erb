<% uploaded = current_user && @my_submission&.image&.attached? %>

<% if !current_user %>
  <%# ── STEP 1: Not logged in ── %>
  <% bg = @submissions.find { |s| s.image.attached? } %>
  <div style="background: #c8bfb4; min-height: 100vh; display: flex; flex-direction: column; position: relative; overflow: hidden;">

    <%# Blurred background — single image stretched to fill %>
    <% if bg %>
      <img src="<%= url_for(bg.image) %>" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; filter: blur(20px) brightness(0.55); transform: scale(1.1); pointer-events: none; z-index: 0;">
    <% end %>

    <%# Content %>
    <div style="position: relative; z-index: 1; flex: 1; display: flex; align-items: center; justify-content: center; padding: 2rem;">
      <div style="background: white; border-radius: 1.5rem; padding: 2rem 2.5rem; border: 1px solid #e2ddd8; max-width: 22rem; width: 100%; box-shadow: 0 8px 40px rgba(0,0,0,0.15); text-align: center;">
        <p class="font-handwritten" style="font-size: 1.6rem; color: #1a1a1a; margin-bottom: 0.35rem;">See what everyone drew today</p>
        <p class="font-sans" style="font-size: 0.85rem; color: #999; margin-bottom: 1.5rem; line-height: 1.5;">Create a free account, upload your drawing, and unlock today's community gallery.</p>

        <%= link_to "/auth/google_oauth2", style: "display: flex; align-items: center; justify-content: center; gap: 0.6rem; background: white; color: #333; border: 1.5px solid #e2ddd8; border-radius: 0.75rem; padding: 0.7rem 1rem; font-size: 0.9rem; font-weight: 600; text-decoration: none; width: 100%; box-sizing: border-box; margin-bottom: 1rem;" do %>
          <svg width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg"><path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4"/><path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 009 18z" fill="#34A853"/><path d="M3.964 10.71A5.41 5.41 0 013.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 000 9c0 1.452.348 2.827.957 4.042l3.007-2.332z" fill="#FBBC05"/><path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 00.957 4.958L3.964 6.29C4.672 4.163 6.656 3.58 9 3.58z" fill="#EA4335"/></svg>
          Continue with Google
        <% end %>

        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
          <div style="flex: 1; height: 1px; background: #e2ddd8;"></div>
          <span class="font-sans" style="font-size: 0.8rem; color: #bbb;">or</span>
          <div style="flex: 1; height: 1px; background: #e2ddd8;"></div>
        </div>

        <%= form_with url: sign_up_path, method: :post do |f| %>
          <%= f.hidden_field :return_to, value: done_path %>
          <div style="display: flex; flex-direction: column; gap: 0.65rem;">
            <%= f.text_field :username, placeholder: "Username", required: true, style: "width: 100%; padding: 0.7rem 1rem; border: 1.5px solid #e2ddd8; border-radius: 0.75rem; font-size: 0.9rem; outline: none; box-sizing: border-box;" %>
            <%= f.email_field :email, placeholder: "Email", required: true, style: "width: 100%; padding: 0.7rem 1rem; border: 1.5px solid #e2ddd8; border-radius: 0.75rem; font-size: 0.9rem; outline: none; box-sizing: border-box;" %>
            <%= f.password_field :password, placeholder: "Password (6+ characters)", required: true, style: "width: 100%; padding: 0.7rem 1rem; border: 1.5px solid #e2ddd8; border-radius: 0.75rem; font-size: 0.9rem; outline: none; box-sizing: border-box;" %>
            <%= f.submit "Create free account", class: "btn btn-black btn-lg w-full rounded-2xl" %>
          </div>
        <% end %>

        <p class="font-sans" style="margin-top: 1rem; font-size: 0.82rem; color: #aaa;">
          Already have an account? <%= link_to "Sign in", sign_in_path, style: "color: #1a1a1a; font-weight: 600;" %>
        </p>
      </div>
    </div>

  </div>

<% elsif !uploaded %>
  <%# ── STEP 2: Logged in, no upload yet ── %>
  <% bg = @submissions.find { |s| s.image.attached? } %>
  <div style="background: #111; min-height: 100vh; display: flex; flex-direction: column; position: relative; overflow: hidden;">

    <%# Blurred background — single image stretched to fill %>
    <% if bg %>
      <img src="<%= url_for(bg.image) %>" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; filter: blur(20px) brightness(0.25); transform: scale(1.1); pointer-events: none; z-index: 0;">
    <% end %>

    <%# Content %>
    <div style="position: relative; z-index: 1; flex: 1; display: flex; align-items: center; justify-content: center; padding: 2rem;">
      <div style="text-align: center; max-width: 26rem; width: 100%;">

        <%= image_tag "mascotte_photo.png", style: "height: 10rem; width: auto; margin-bottom: 1rem; display: block; margin-left: auto; margin-right: auto;", alt: "" %>
        <h1 class="font-handwritten" style="font-size: 2rem; color: white; margin-bottom: 0.5rem;">Share your drawing!</h1>
        <p class="font-sans" style="font-size: 0.9rem; color: rgba(255,255,255,0.5); margin-bottom: 2rem; line-height: 1.5;">Upload your drawing to unlock today's community gallery.</p>

        <div style="background: rgba(255,255,255,0.07); border-radius: 1.5rem; padding: 1.75rem; border: 1px solid rgba(255,255,255,0.1);">
          <% if mobile? %>
            <%# Mobile: direct camera upload %>
            <%= form_with url: submissions_path, method: :post, html: { enctype: "multipart/form-data" } do |f| %>
              <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                <label for="mobile-image-input" style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.5rem; border: 2px dashed rgba(255,255,255,0.2); border-radius: 1rem; padding: 1.5rem; cursor: pointer; overflow: hidden; position: relative;">
                  <div id="mobile-preview-container" style="display: none; width: 100%;">
                    <img id="mobile-preview" style="width: 100%; border-radius: 0.5rem; object-fit: cover; max-height: 220px; display: block;">
                  </div>
                  <div id="mobile-placeholder">
                    <span style="font-size: 2rem;">📷</span>
                    <span class="font-sans" style="font-size: 0.875rem; color: rgba(255,255,255,0.5); display: block; margin-top: 0.25rem;">Tap to take or pick a photo</span>
                  </div>
                  <%= f.file_field :image, accept: "image/*", capture: "environment", style: "display: none;", id: "mobile-image-input" %>
                </label>
                <%= f.submit "Upload my drawing", class: "btn btn-black w-full rounded-2xl" %>
              </div>
            <% end %>
            <script>
              document.getElementById("mobile-image-input").addEventListener("change", function() {
                const file = this.files[0];
                if (!file) return;
                const reader = new FileReader();
                reader.onload = function(e) {
                  document.getElementById("mobile-preview").src = e.target.result;
                  document.getElementById("mobile-preview-container").style.display = "block";
                  document.getElementById("mobile-placeholder").style.display = "none";
                };
                reader.readAsDataURL(file);
              });
            </script>
          <% else %>
            <%# Desktop: QR code + polling %>
            <% qr_url = done_url(host: request.host, port: request.port) %>
            <% qr = RQRCode::QRCode.new(qr_url) %>
            <p class="font-sans" style="font-size: 0.95rem; font-weight: 600; color: white; margin-bottom: 0.25rem;">Scan with your phone</p>
            <p class="font-sans" style="font-size: 0.82rem; color: rgba(255,255,255,0.45); margin-bottom: 1.25rem;">Take a photo of your drawing and upload it directly.</p>
            <div style="display: inline-block; background: white; padding: 1rem; border-radius: 1rem;">
              <% svg = qr.as_svg(viewbox: true, use_path: true) %>
              <% svg = svg.sub('<svg ', '<svg width="150" height="150" ') %>
              <%= svg.html_safe %>
            </div>
            <p class="font-sans" style="font-size: 0.78rem; color: rgba(255,255,255,0.3); margin-top: 1rem;">Waiting for your upload…</p>

            <div style="display: flex; align-items: center; gap: 0.75rem; margin: 1.25rem 0;">
              <div style="flex: 1; height: 1px; background: rgba(255,255,255,0.1);"></div>
              <span class="font-sans" style="font-size: 0.8rem; color: rgba(255,255,255,0.3);">or</span>
              <div style="flex: 1; height: 1px; background: rgba(255,255,255,0.1);"></div>
            </div>

            <%= form_with url: submissions_path, method: :post, html: { enctype: "multipart/form-data" } do |f| %>
              <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                <label style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; border: 1.5px dashed rgba(255,255,255,0.2); border-radius: 0.75rem; padding: 0.75rem 1rem; cursor: pointer;">
                  <span style="font-size: 1rem;">📎</span>
                  <span class="font-sans" style="font-size: 0.85rem; color: rgba(255,255,255,0.5);">Upload a file from this device</span>
                  <%= f.file_field :image, accept: "image/*", style: "display: none;" %>
                </label>
                <%= f.submit "Upload drawing", class: "btn btn-black w-full rounded-2xl" %>
              </div>
            <% end %>

            <script>
              setInterval(function() {
                fetch("/upload_status")
                  .then(function(r) { return r.json(); })
                  .then(function(data) { if (data.uploaded) window.location.href = "<%= done_path %>"; });
              }, 3000);
            </script>
          <% end %>
        </div>

        <p class="font-sans" style="margin-top: 1.5rem; font-size: 0.8rem;">
          <%= link_to "Skip for now →", root_path, style: "color: rgba(255,255,255,0.25); text-decoration: none;" %>
        </p>

      </div>
    </div>
  </div>

<% else %>
  <%# ── STEP 3: Uploaded — Success! ── %>
  <%# Lightbox %>
  <div id="lightbox" onclick="this.style.display='none'" style="display: none; position: fixed; inset: 0; z-index: 100; background: rgba(0,0,0,0.92); align-items: center; justify-content: center; cursor: zoom-out;">
    <img id="lightbox-img" style="max-width: 92vw; max-height: 92vh; object-fit: contain; border-radius: 0.5rem;">
  </div>
  <script>
    function openLightbox(src) {
      document.getElementById("lightbox-img").src = src;
      document.getElementById("lightbox").style.display = "flex";
    }
    document.addEventListener("keydown", function(e) { if (e.key === "Escape") document.getElementById("lightbox").style.display = "none"; });
  </script>

  <div style="background: #f5f2ee; min-height: 100vh; padding: 4rem 1.5rem 6rem;">
    <div style="max-width: 52rem; margin: 0 auto;">

      <%# ── Congrats ── %>
      <div style="text-align: center; margin-bottom: 3rem; max-width: 36rem; margin-left: auto; margin-right: auto;">
        <%= image_tag "congrats.png", style: "width: 14rem; display: block; margin: 0 auto 1rem;", alt: "" %>
        <h1 class="font-handwritten" style="font-size: 3rem; color: #1a1a1a; line-height: 1.1; margin-bottom: 1rem;">
          You showed up today!
        </h1>
        <% if @streak > 0 %>
          <div style="display: inline-flex; align-items: center; gap: 0.5rem; background: white; border-radius: 999px; padding: 0.45rem 1rem; box-shadow: 0 2px 8px rgba(0,0,0,0.07); margin-bottom: 1rem;">
            <div style="position: relative; width: 1.6rem; height: 2rem; flex-shrink: 0;">
              <svg viewBox="0 0 36 48" fill="none" xmlns="http://www.w3.org/2000/svg" style="width: 100%; height: 100%; filter: drop-shadow(0 2px 6px rgba(255,212,0,0.5));">
                <path d="M24 2L4 26L15 26L11 46L32 22L21 22Z" fill="#FFD400"/>
              </svg>
              <span class="font-sans" style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; padding-left: 0.1rem; font-size: <%= @streak >= 10 ? '0.5rem' : '0.65rem' %>; font-weight: 900; color: #1a1a1a; line-height: 1;"><%= @streak %></span>
            </div>
            <span class="font-sans" style="font-size: 0.82rem; font-weight: 700; color: #1a1a1a;"><%= @streak %> day streak</span>
          </div>
        <% end %>
        <p class="font-sans" style="font-size: 0.85rem; color: #bbb;">See you tomorrow</p>
      </div>

<%# ── Today's drawings ── %>
      <% others = @submissions.reject { |s| s == @my_submission }.select { |s| s.image.attached? } %>
      <% all_drawings = ([@my_submission] + others).compact %>
      <% if all_drawings.any? %>
        <div>
          <div style="margin-bottom: 1rem;">
            <p class="font-sans" style="font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #bbb;">Today's drawings</p>
          </div>

          <%# First row: my drawing (flex: 2) + first other (flex: 1) %>
          <% first_other = all_drawings.find { |s| s != @my_submission } %>
          <div style="display: flex; gap: 0.75rem; margin-bottom: 0.75rem; align-items: stretch; max-height: 22rem;">

            <%# My drawing %>
            <% my_total = @my_submission.total_cheers %>
            <div style="flex: 2; position: relative; border-radius: 1rem; overflow: hidden; background: #e8e3db; box-shadow: 0 2px 12px rgba(0,0,0,0.1);">
              <%= image_tag url_for(@my_submission.image), style: "width: 100%; height: 100%; object-fit: cover; display: block; cursor: zoom-in;", onclick: "openLightbox(this.src)" %>
              <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 0.4rem 0.5rem; background: linear-gradient(transparent, rgba(0,0,0,0.65)); display: flex; align-items: center; justify-content: space-between;">
                <p class="font-sans" style="font-size: 0.7rem; color: rgba(255,255,255,0.9); font-weight: 600;"><%= @my_submission.user.username %></p>
                <% if my_total > 0 %>
                  <div style="display: flex; align-items: center; gap: 0.25rem;">
                    <span style="font-size: 0.8rem;">👏</span>
                    <span class="font-sans" style="font-size: 0.7rem; color: white; font-weight: 700;"><%= my_total %></span>
                  </div>
                <% end %>
              </div>
            </div>

            <%# First other drawing %>
            <% if first_other %>
              <div style="flex: 1; aspect-ratio: 3/4; position: relative; border-radius: 1rem; overflow: hidden; background: #e8e3db; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
                <%= image_tag url_for(first_other.image), style: "width: 100%; height: 100%; object-fit: cover; display: block; cursor: zoom-in;", onclick: "openLightbox(this.src)" %>
                <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 0.4rem 0.5rem; background: linear-gradient(transparent, rgba(0,0,0,0.65)); display: flex; align-items: center; justify-content: space-between;">
                  <p class="font-sans" style="font-size: 0.7rem; color: rgba(255,255,255,0.9); font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= first_other.user.username %></p>
                  <%= render "cheers/button", submission: first_other %>
                </div>
              </div>
            <% end %>
          </div>

          <%# Remaining drawings in a 3-col grid %>
          <% rest = all_drawings.reject { |s| s == @my_submission || s == first_other } %>
          <% if rest.any? %>
            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem;">
              <% rest.each do |submission| %>
                <div style="position: relative; border-radius: 1rem; overflow: hidden; background: #e8e3db; aspect-ratio: 3/4; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
                  <%= image_tag url_for(submission.image), style: "width: 100%; height: 100%; object-fit: cover; display: block; cursor: zoom-in;", onclick: "openLightbox(this.src)" %>
                  <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 0.4rem 0.5rem; background: linear-gradient(transparent, rgba(0,0,0,0.65)); display: flex; align-items: center; justify-content: space-between;">
                    <p class="font-sans" style="font-size: 0.7rem; color: rgba(255,255,255,0.9); font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= submission.user.username %></p>
                    <%= render "cheers/button", submission: submission %>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>

    </div>
  </div>
<% end %>
