<div style="background: #f5f2ee; min-height: 100vh; padding: 3rem 1.5rem 5rem;">
  <div style="max-width: 52rem; margin: 0 auto;">

    <%# Top section: congrats + sign up %>
    <div style="display: flex; align-items: center; gap: 3rem; flex-wrap: wrap; justify-content: center; margin-bottom: 3.5rem;">

      <%# Left — congrats %>
      <div class="flex flex-col items-center text-center" style="gap: 1rem; flex: 1; min-width: 16rem;">
        <%= image_tag "congrats.png", style: "width: 15rem;", alt: "Congrats" %>
        <h1 class="font-handwritten" style="font-size: 2rem; color: #1a1a1a; line-height: 1.2;">
          Congrats for showing up today!
        </h1>
        <p class="font-sans" style="font-size: 0.95rem; color: #888; line-height: 1.5;">
          See you tomorrow for a new challenge.
        </p>
        <%= link_to "Back to home", root_path, class: "font-sans", style: "font-size: 0.82rem; color: #bbb; text-decoration: none;" %>
      </div>

      <%# Right — upload or sign up %>
      <div style="flex: 1; min-width: 18rem; max-width: 22rem;">
        <% if current_user %>
          <div style="background: white; border-radius: 1.5rem; padding: 1.75rem; border: 1px solid #e2ddd8;">
            <p class="font-sans" style="font-size: 1rem; font-weight: 700; color: #1a1a1a; margin-bottom: 0.35rem;">See what everyone drew today</p>
            <p class="font-sans" style="font-size: 0.85rem; color: #999; margin-bottom: 1.25rem; line-height: 1.5;">Share your drawing to unlock today's community gallery.</p>

            <% if @my_submission&.image&.attached? %>
              <div style="border-radius: 1rem; overflow: hidden; margin-bottom: 1.25rem;">
                <%= image_tag url_for(@my_submission.image), style: "width: 100%; object-fit: cover; display: block;" %>
              </div>
              <p class="font-sans text-center" style="font-size: 0.82rem; color: #aaa; margin-bottom: 1rem;">Drawing uploaded ✓</p>
            <% end %>

            <% if mobile? %>
              <%# On mobile: just show the upload form %>
              <%= form_with url: submissions_path, method: :post, html: { enctype: "multipart/form-data", id: "mobile-upload-form" } do |f| %>
                <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                  <label for="mobile-image-input" style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.5rem; border: 2px dashed #e2ddd8; border-radius: 1rem; padding: 1.5rem; cursor: pointer; background: #faf9f7; overflow: hidden; position: relative;">
                    <div id="mobile-preview-container" style="display: none; width: 100%;">
                      <img id="mobile-preview" style="width: 100%; border-radius: 0.5rem; object-fit: cover; max-height: 220px; display: block;">
                    </div>
                    <div id="mobile-placeholder">
                      <span style="font-size: 2rem;">📷</span>
                      <span class="font-sans" style="font-size: 0.875rem; color: #888; display: block; margin-top: 0.25rem;">Tap to take or pick a photo</span>
                    </div>
                    <%= f.file_field :image, accept: "image/*", capture: "environment", style: "display: none;", id: "mobile-image-input" %>
                  </label>
                  <%= f.submit @my_submission&.image&.attached? ? "Replace drawing" : "Upload my drawing", class: "btn btn-black w-full rounded-2xl", id: "mobile-submit-btn" %>
                </div>
              <% end %>
              <script>
                document.getElementById("mobile-image-input").addEventListener("change", function() {
                  const file = this.files[0];
                  if (!file) return;
                  const reader = new FileReader();
                  reader.onload = function(e) {
                    document.getElementById("mobile-preview").src = e.target.result;
                    document.getElementById("mobile-preview-container").style.display = "block";
                    document.getElementById("mobile-placeholder").style.display = "none";
                  };
                  reader.readAsDataURL(file);
                });
              </script>

            <% else %>
              <%# On desktop: QR code is the primary option %>
              <% qr_url = done_url(host: request.host, port: request.port) %>
              <% qr = RQRCode::QRCode.new(qr_url) %>
              <div style="text-align: center;">
                <p class="font-sans" style="font-size: 0.9rem; font-weight: 600; color: #1a1a1a; margin-bottom: 0.35rem;">Scan with your phone</p>
                <p class="font-sans" style="font-size: 0.82rem; color: #aaa; margin-bottom: 1rem;">Take a photo of your drawing and upload it directly.</p>
                <div style="display: inline-block; background: white; padding: 1rem; border-radius: 1rem; border: 1px solid #e2ddd8;">
                  <% svg = qr.as_svg(viewbox: true, use_path: true) %>
                  <% svg = svg.sub('<svg ', '<svg width="140" height="140" ') %>
                  <%= svg.html_safe %>
                </div>
              </div>

              <div style="display: flex; align-items: center; gap: 0.75rem; margin: 1.25rem 0;">
                <div style="flex: 1; height: 1px; background: #f0ece6;"></div>
                <span class="font-sans" style="font-size: 0.8rem; color: #ccc;">or</span>
                <div style="flex: 1; height: 1px; background: #f0ece6;"></div>
              </div>

              <%= form_with url: submissions_path, method: :post, html: { enctype: "multipart/form-data" } do |f| %>
                <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                  <label style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; border: 1.5px dashed #e2ddd8; border-radius: 0.75rem; padding: 0.75rem 1rem; cursor: pointer; background: #faf9f7;">
                    <span style="font-size: 1rem;">📎</span>
                    <span class="font-sans" style="font-size: 0.85rem; color: #888;">Upload a file from this device</span>
                    <%= f.file_field :image, accept: "image/*", style: "display: none;" %>
                  </label>
                  <%= f.submit @my_submission&.image&.attached? ? "Replace drawing" : "Upload drawing", class: "btn btn-black w-full rounded-2xl" %>
                </div>
              <% end %>
            <% end %>
          </div>

        <% else %>
          <div style="background: white; border-radius: 1.5rem; padding: 1.75rem; border: 1px solid #e2ddd8;">
            <p class="font-sans" style="font-size: 1.1rem; font-weight: 700; color: #1a1a1a; margin-bottom: 0.4rem;">See what everyone drew today</p>
            <p class="font-sans" style="font-size: 0.85rem; color: #888; margin-bottom: 0.25rem; line-height: 1.5;">Create a free account, share your drawing, and unlock today's community gallery.</p>
            <p class="font-sans" style="font-size: 0.8rem; color: #aaa; margin-bottom: 1.5rem; font-weight: 600;">Free, always.</p>

            <%= link_to "/auth/google_oauth2", style: "display: flex; align-items: center; justify-content: center; gap: 0.6rem; background: white; color: #333; border: 1.5px solid #e2ddd8; border-radius: 0.75rem; padding: 0.7rem 1rem; font-size: 0.9rem; font-weight: 600; text-decoration: none; width: 100%; box-sizing: border-box;" do %>
              <svg width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg"><path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4"/><path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 009 18z" fill="#34A853"/><path d="M3.964 10.71A5.41 5.41 0 013.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 000 9c0 1.452.348 2.827.957 4.042l3.007-2.332z" fill="#FBBC05"/><path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 00.957 4.958L3.964 6.29C4.672 4.163 6.656 3.58 9 3.58z" fill="#EA4335"/></svg>
              Continue with Google
            <% end %>

            <div style="display: flex; align-items: center; gap: 0.75rem; margin: 1rem 0;">
              <div style="flex: 1; height: 1px; background: #e2ddd8;"></div>
              <span class="font-sans" style="font-size: 0.8rem; color: #bbb;">or</span>
              <div style="flex: 1; height: 1px; background: #e2ddd8;"></div>
            </div>

            <%= form_with url: sign_up_path, method: :post do |f| %>
              <%= f.hidden_field :return_to, value: done_path %>
              <div style="display: flex; flex-direction: column; gap: 0.65rem;">
                <%= f.text_field :username, placeholder: "Username", required: true, style: "width: 100%; padding: 0.7rem 1rem; border: 1.5px solid #e2ddd8; border-radius: 0.75rem; font-size: 0.9rem; outline: none; box-sizing: border-box;" %>
                <%= f.email_field :email, placeholder: "Email", required: true, style: "width: 100%; padding: 0.7rem 1rem; border: 1.5px solid #e2ddd8; border-radius: 0.75rem; font-size: 0.9rem; outline: none; box-sizing: border-box;" %>
                <%= f.password_field :password, placeholder: "Password (6+ characters)", required: true, style: "width: 100%; padding: 0.7rem 1rem; border: 1.5px solid #e2ddd8; border-radius: 0.75rem; font-size: 0.9rem; outline: none; box-sizing: border-box;" %>
                <%= f.submit "Create free account", class: "btn btn-black btn-lg w-full rounded-2xl" %>
              </div>
            <% end %>

            <p class="font-sans text-center" style="margin-top: 1rem; font-size: 0.82rem; color: #aaa;">
              Already have an account? <%= link_to "Sign in", sign_in_path, style: "color: #1a1a1a; font-weight: 600;" %>
            </p>
          </div>
        <% end %>
      </div>

    </div>

    <%# Community gallery %>
    <% if @submissions.any? %>
      <div>
        <div style="margin-bottom: 1.5rem;">
          <h2 class="font-handwritten" style="font-size: 1.5rem; color: #1a1a1a;">Today's drawings</h2>
          <p class="font-sans" style="font-size: 0.875rem; color: #999; margin-top: 0.25rem;">
            <%= @submissions.size %> <%= @submissions.size == 1 ? "person" : "people" %> shared their work today.
          </p>
        </div>

        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem;">
          <% @submissions.each do |submission| %>
            <% next unless submission.image.attached? %>
            <% is_mine = submission == @my_submission %>
            <% my_cheer = @my_cheers[submission.id] %>
            <% my_cheer_count = my_cheer&.count || 0 %>
            <% total = submission.total_cheers %>
            <div style="position: relative; border-radius: 1rem; overflow: hidden; background: #e8e3db; aspect-ratio: 3/4; <%= is_mine ? 'box-shadow: 0 0 0 3px #1a1a1a;' : '' %>">
              <%= image_tag url_for(submission.image), style: "width: 100%; height: 100%; object-fit: cover; display: block;" %>
              <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 0.5rem 0.75rem; background: linear-gradient(transparent, rgba(0,0,0,0.6));">
                <div style="display: flex; align-items: center; justify-content: space-between;">
                  <p class="font-sans" style="font-size: 0.75rem; color: rgba(255,255,255,0.95); font-weight: 600;">
                    <%= is_mine ? "You" : submission.user.username %>
                  </p>
                  <% unless is_mine %>
                    <% can_cheer = current_user && my_cheer_count < Cheer::MAX_PER_USER %>
                    <% if can_cheer %>
                      <%= button_to cheers_path, method: :post, params: { submission_id: submission.id }, style: "background: rgba(255,255,255,0.2); border: none; border-radius: 999px; padding: 0.2rem 0.5rem; cursor: pointer; display: flex; align-items: center; gap: 0.25rem;" do %>
                        <span style="font-size: 0.8rem;">👏</span>
                        <span class="font-sans" style="font-size: 0.7rem; color: white; font-weight: 600;"><%= total > 0 ? total : "" %></span>
                      <% end %>
                    <% else %>
                      <div style="display: flex; align-items: center; gap: 0.25rem; padding: 0.2rem 0.5rem;">
                        <span style="font-size: 0.8rem;">👏</span>
                        <span class="font-sans" style="font-size: 0.7rem; color: rgba(255,255,255,0.8); font-weight: 600;"><%= total > 0 ? total : "" %></span>
                      </div>
                    <% end %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

  </div>
</div>
