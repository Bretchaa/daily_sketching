<div style="background: #f5f2ee; min-height: 100vh;">

  <%# Hero card %>
  <div style="display: flex; justify-content: center; padding: 5rem 1.5rem 3rem;">
    <div class="w-full" style="max-width: 28rem;">
      <div class="bg-white rounded-[2rem] shadow-md" style="padding: 2.5rem; border: 1px solid #e2ddd8; transform: rotate(-0.3deg);">
        <div class="flex flex-col" style="gap: 1.5rem;">

          <% if current_user %>
            <%# Logged in state %>
            <%= image_tag "logo_home.svg", class: "w-64", alt: "Daily Sketching" %>

            <div style="display: flex; align-items: center; gap: 0.75rem;">
              <% if current_user.avatar_url.present? %>
                <img src="<%= current_user.avatar_url %>" style="width: 2.75rem; height: 2.75rem; border-radius: 999px; flex-shrink: 0;">
              <% else %>
                <div style="width: 2.75rem; height: 2.75rem; border-radius: 999px; background: #1a1a1a; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                  <span class="font-sans" style="color: white; font-weight: 700; font-size: 1rem;"><%= current_user.username[0].upcase %></span>
                </div>
              <% end %>
              <div>
                <p class="font-sans" style="font-size: 0.75rem; color: #aaa; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">Welcome back</p>
                <p class="font-sans" style="font-size: 1rem; font-weight: 700; color: #1a1a1a;"><%= current_user.username %> 👋</p>
              </div>
            </div>

            <div>
              <h1 class="font-handwritten" style="font-size: 2rem; line-height: 1.2; color: #1a1a1a;">
                Ready for today's challenge?
              </h1>
              <p class="font-sans" style="margin-top: 0.5rem; font-size: 0.95rem; color: #888; line-height: 1.5;">
                A new gesture drawing session is waiting for you.
              </p>
            </div>

          <% else %>
            <%# Logged out state %>
            <%= image_tag "logo_home.svg", class: "w-64", alt: "Daily Sketching" %>

            <div>
              <h1 class="font-handwritten" style="font-size: 2rem; line-height: 1.2; color: #1a1a1a;">
                Practice drawing.<br>Every day.
              </h1>
              <p class="font-sans" style="margin-top: 0.5rem; font-size: 0.95rem; color: #888; line-height: 1.5;">
                A 15-minute guided drawing challenge per day.
              </p>
            </div>
          <% end %>

          <%= link_to "Start today's challenge", today_challenge_path,
            class: "btn btn-black btn-lg w-full rounded-2xl" %>

          <% if !current_user %>
            <p class="font-sans text-center" style="font-size: 0.82rem; color: #bbb; margin-top: -0.5rem;">
              <%= link_to "Sign in", sign_in_path, style: "color: #888; font-weight: 600; text-decoration: none;" %> · <%= link_to "Create account", sign_up_path, style: "color: #888; font-weight: 600; text-decoration: none;" %>
            </p>
          <% else %>
            <p class="font-sans text-center" style="font-size: 0.82rem; color: #bbb; margin-top: -0.5rem;">
              <%= link_to "Upload today's drawing →", done_path, style: "color: #888; font-weight: 600; text-decoration: none;" %>
               · <%= link_to "Sign out", sign_out_path, data: { turbo_method: :delete }, style: "color: #bbb; text-decoration: none;" %>
            </p>
          <% end %>

        </div>
      </div>
    </div>
  </div>

  <%# Community section %>
  <div style="max-width: 52rem; margin: 0 auto; padding: 0 1.5rem 5rem;">

    <div style="margin-bottom: 1.75rem;">
      <h2 class="font-handwritten" style="font-size: 1.5rem; color: #1a1a1a;">What the community drew yesterday</h2>
      <p class="font-sans" style="font-size: 0.875rem; color: #999; margin-top: 0.25rem;">
        Theme: Gesture drawing · 126 people showed up. Here's what they made.
      </p>
    </div>

    <%# Drawing grid — placeholder with real pose images for now %>
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem;">
      <% [
        "DSC_0096-837x1536.jpg",
        "DSC_0305.jpg",
        "DSC_0306-DEJ-2024.jpg",
        "DSC_0347.jpg",
        "DSC_0422.jpg",
        "DSC_0452-794x1000.jpg"
      ].each_with_index do |filename, i| %>
        <div style="position: relative; border-radius: 1rem; overflow: hidden; background: #e8e3db; aspect-ratio: 3/4;">
          <img src="https://assets.dailysketching.app/poses/gesture/<%= filename %>"
               style="width: 100%; height: 100%; object-fit: cover; display: block;">
          <%# Username overlay %>
          <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 0.5rem 0.75rem; background: linear-gradient(transparent, rgba(0,0,0,0.5));">
            <p class="font-sans" style="font-size: 0.75rem; color: rgba(255,255,255,0.9); font-weight: 600;">sketchlover<%= i + 1 %></p>
          </div>
        </div>
      <% end %>
    </div>

    <%# CTA nudge %>
    <div style="margin-top: 1.5rem; text-align: center;">
      <p class="font-sans" style="font-size: 0.875rem; color: #aaa;">
        Your drawing could be here tomorrow.
        <%= link_to "Start today's challenge →", today_challenge_path, style: "color: #1a1a1a; font-weight: 700; text-decoration: none;" %>
      </p>
    </div>

  </div>

</div>
