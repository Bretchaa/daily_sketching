<div class="min-h-screen flex flex-col items-center justify-center px-6" style="background: #f5f2ee;">
  <div class="w-full" style="max-width: 24rem;">

    <%= image_tag "logo_home.svg", class: "w-48", alt: "Daily Sketching", style: "margin: 0 auto 2rem;" %>

    <div class="bg-white rounded-[2rem] shadow-md" style="padding: 2rem; border: 1px solid #e2ddd8;">

      <p class="font-sans" style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: #aaa; margin-bottom: 0.35rem;">Uploading as</p>
      <p class="font-sans" style="font-size: 1rem; font-weight: 700; color: #1a1a1a; margin-bottom: 1.5rem;"><%= @user.username %></p>

      <% if @existing&.image&.attached? %>
        <div style="border-radius: 1rem; overflow: hidden; margin-bottom: 1.25rem;">
          <%= image_tag url_for(@existing.image), style: "width: 100%; object-fit: cover; display: block;" %>
        </div>
        <p class="font-sans text-center" style="font-size: 0.82rem; color: #aaa; margin-bottom: 1rem;">Drawing uploaded ✓ — upload again to replace it.</p>
      <% end %>

      <%= form_with url: upload_path(token: params[:token]), method: :post, html: { enctype: "multipart/form-data" } do |f| %>
        <div style="display: flex; flex-direction: column; gap: 1rem;">
          <label style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.75rem; border: 2px dashed #e2ddd8; border-radius: 1rem; padding: 2rem 1rem; cursor: pointer; background: #faf9f7;">
            <span style="font-size: 2.5rem;">📷</span>
            <span class="font-sans" style="font-size: 0.9rem; color: #888; text-align: center;">Tap to take a photo<br>or pick from your gallery</span>
            <%= f.file_field :image, accept: "image/*", capture: "environment", style: "display: none;" %>
          </label>
          <%= f.submit "Upload my drawing", class: "btn btn-black btn-lg w-full rounded-2xl" %>
        </div>
      <% end %>

    </div>
  </div>
</div>
